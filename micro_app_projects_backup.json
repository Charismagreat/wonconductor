    "description": null,
    "sources": "[{\"id\":\"finance-hub-bank-table\",\"name\":\"은행 계좌 거래 내역 (FinanceHub)\"}]",
    "tags": "[\"컴팩트한 디자인\"]",
    "templateId": "custom-app",
    "mappingConfig": "[{\"sourceColumn\":\"date\",\"displayName\":\"date\",\"type\":\"date\"},{\"sourceColumn\":\"_bankName\",\"displayName\":\"_bankName\",\"type\":\"string\"},{\"sourceColumn\":\"accountNumber\",\"displayName\":\"accountNumber\",\"type\":\"string\"},{\"sourceColumn\":\"description\",\"displayName\":\"description\",\"type\":\"string\"},{\"sourceColumn\":\"withdrawal\",\"displayName\":\"withdrawal\",\"type\":\"currency\"},{\"sourceColumn\":\"deposit\",\"displayName\":\"deposit\",\"type\":\"currency\"},{\"sourceColumn\":\"balance\",\"displayName\":\"balance\",\"type\":\"currency\"}]",
    "uiSettings": "{\"theme\":\"slate\",\"title\":\"자금일보 Intelligence\",\"description\":\"기업의 유동성 현황과 일일 자금 흐름을 정밀하게 통찰하는 프리미엄 재무 관리 솔루션입니다. 복잡한 자금 지표를 직관적인 컴팩트 뷰로 재구성하여 최적의 의사결정 환경을 제공합니다.\",\"tags\":[\"컴팩트한 디자인\"]}",
