  {
    "id": "94effced-87d7-4361-bfcc-fe0068e3b97f",
    "name": "자금현황",
    "description": null,
    "sources": "[{\"id\":\"finance-hub-bank-table\",\"name\":\"은행 계좌 거래 내역 (FinanceHub)\"},{\"id\":\"finance-hub-card-table\",\"name\":\"신용카드 거래 내역 (FinanceHub)\"}]",
    "tags": "[\"'은행별 잔액 파이 차트', '은행명, 계좌번호, 잔액', '은행 거래 내역 중 최근 7일간 거래 내역', '최근 3개월 월별 카드 사용액 막대 그래프', '최근 7일간 카드 사용 내역'\"]",
    "templateId": "custom-app",
    "mappingConfig": "[{\"variable\":\"accounts\",\"source\":\"finance-hub-bank-table\",\"mapping\":{\"bankName\":\"_bankName\",\"name\":\"accountName\",\"balance\":\"balance\",\"accountNo\":\"accountNumber\"}},{\"variable\":\"bankTransactions\",\"source\":\"finance-hub-bank-table\",\"filter\":\"date >= '2026-04-07'\",\"mapping\":{\"date\":\"date\",\"description\":\"accountName\",\"amount\":\"balance\",\"bankName\":\"_bankName\"}},{\"variable\":\"cardTransactions\",\"source\":\"finance-hub-card-table\",\"filter\":\"approvalDate >= '2026-04-07'\",\"mapping\":{\"date\":\"approvalDate\",\"description\":\"merchantName\",\"amount\":\"amount\",\"bankName\":\"_bankName\"}},{\"sourceColumn\":\"date\",\"displayName\":\"거래일자\",\"type\":\"date\"},{\"sourceColumn\":\"accountNumber\",\"displayName\":\"계좌번호\",\"type\":\"string\"},{\"sourceColumn\":\"description\",\"displayName\":\"거래내역\",\"type\":\"string\"},{\"sourceColumn\":\"accountName\",\"displayName\":\"계좌명\",\"type\":\"string\"},{\"sourceColumn\":\"withdrawal\",\"displayName\":\"출금액\",\"type\":\"currency\"},{\"sourceColumn\":\"balance\",\"displayName\":\"balance\",\"type\":\"currency\"},{\"sourceColumn\":\"_bankName\",\"displayName\":\"은행명\",\"type\":\"string\"},{\"sourceColumn\":\"deposit\",\"displayName\":\"입금액\",\"type\":\"currency\"}]",
    "uiSettings": "{\"theme\":\"indigo\",\"title\":\"기업 자금현황 실시간 대시보드\",\"description\":\"[태그 반영] '은행별 잔액 파이 차트'로 자산 비중을 확인하고, '은행명/계좌번호/잔액' 리스트와 '최근 7일간의 은행 거래 및 카드 사용 내역'을 상세히 분석합니다. '최근 3개월 월별 카드 사용액 막대 그래프'를 통해 지출 추이를 모니터링합니다.\",\"customHtml\":\"<div class=\\\"p-6 bg-gray-50 min-h-screen font-sans\\\">\\n  <!-- 상단 가용 자금 카드 -->\\n  <div class=\\\"mb-8 bg-white rounded-2xl shadow-sm p-6 border border-indigo-100\\\">\\n    <h2 class=\\\"text-sm font-medium text-gray-500 mb-1\\\">Net Position (현재 가용 자금)</h2>\\n    <div class=\\\"flex items-baseline gap-2\\\">\\n      <span class=\\\"text-3xl font-bold text-indigo-600\\\">{{netPosition}}</span>\\n      <span class=\\\"text-gray-400\\\">KRW</span>\\n    </div>\\n    <div class=\\\"grid grid-cols-2 gap-4 mt-4 pt-4 border-t border-gray-50\\\">\\n      <div>\\n        <p class=\\\"text-xs text-gray-400\\\">은행 총 잔액</p>\\n        <p class=\\\"text-lg font-semibold text-gray-700\\\">{{bankBalance}}</p>\\n      </div>\\n      <div>\\n        <p class=\\\"text-xs text-gray-400\\\">카드 사용 예정액</p>\\n        <p class=\\\"text-lg font-semibold text-red-500\\\">{{cardSpend}}</p>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <!-- 차트 영역 -->\\n  <div class=\\\"grid grid-cols-1 md:grid-cols-2 gap-6 mb-8\\\">\\n    <div class=\\\"bg-white p-5 rounded-2xl shadow-sm border border-gray-100\\\">\\n      <h3 class=\\\"text-sm font-bold text-gray-700 mb-4\\\">은행별 잔액 비중 (파이 차트)</h3>\\n      <div class=\\\"h-64\\\">\\n        <canvas id=\\\"bankPieChart\\\"></canvas>\\n      </div>\\n    </div>\\n    <div class=\\\"bg-white p-5 rounded-2xl shadow-sm border border-gray-100\\\">\\n      <h3 class=\\\"text-sm font-bold text-gray-700 mb-4\\\">최근 3개월 카드 사용액 (막대 그래프)</h3>\\n      <div class=\\\"h-64\\\">\\n        <canvas id=\\\"cardBarChart\\\"></canvas>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <!-- 은행 계좌 리스트 -->\\n  <div class=\\\"bg-white rounded-2xl shadow-sm border border-gray-100 mb-8 overflow-hidden\\\">\\n    <div class=\\\"p-5 border-b border-gray-50\\\">\\n      <h3 class=\\\"text-sm font-bold text-gray-700\\\">전체 계좌 현황 (은행명, 계좌번호, 잔액)</h3>\\n    </div>\\n    <div class=\\\"overflow-x-auto\\\">\\n      <table class=\\\"w-full text-left text-sm\\\">\\n        <thead class=\\\"bg-gray-50 text-gray-500\\\">\\n          <tr>\\n            <th class=\\\"px-6 py-3 font-medium\\\">은행명</th>\\n            <th class=\\\"px-6 py-3 font-medium\\\">계좌번호</th>\\n            <th class=\\\"px-6 py-3 font-medium text-right\\\">잔액</th>\\n          </tr>\\n        </thead>\\n        <tbody class=\\\"divide-y divide-gray-50\\\">\\n          {{#each accounts}}\\n          <tr class=\\\"hover:bg-indigo-50/30 transition-colors\\\">\\n            <td class=\\\"px-6 py-4 font-medium text-gray-700\\\">{{bankName}}</td>\\n            <td class=\\\"px-6 py-4 text-gray-500\\\">{{accountNo}}</td>\\n            <td class=\\\"px-6 py-4 text-right font-semibold text-gray-800\\\">{{formatNumber balance}}원</td>\\n          </tr>\\n          {{/each}}\\n        </tbody>\\n      </table>\\n    </div>\\n  </div>\\n\\n  <div class=\\\"grid grid-cols-1 lg:grid-cols-2 gap-8\\\">\\n    <!-- 은행 최근 7일 내역 -->\\n    <div class=\\\"bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden\\\">\\n      <div class=\\\"p-5 border-b border-gray-50 bg-indigo-50/50\\\">\\n        <h3 class=\\\"text-sm font-bold text-indigo-900\\\">은행 최근 7일간 거래 내역</h3>\\n      </div>\\n      <ul class=\\\"divide-y divide-gray-50\\\">\\n        {{#each bankTransactions}}\\n        <li class=\\\"p-4 flex justify-between items-center\\\">\\n          <div>\\n            <p class=\\\"text-xs text-gray-400\\\">{{date}} | {{bankName}}</p>\\n            <p class=\\\"font-medium text-gray-800\\\">{{description}}</p>\\n          </div>\\n          <p class=\\\"font-bold text-blue-600\\\">{{formatNumber amount}}원</p>\\n        </li>\\n        {{/each}}\\n      </ul>\\n    </div>\\n\\n    <!-- 카드 최근 7일 내역 -->\\n    <div class=\\\"bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden\\\">\\n      <div class=\\\"p-5 border-b border-gray-50 bg-red-50/50\\\">\\n        <h3 class=\\\"text-sm font-bold text-red-900\\\">최근 7일간 카드 사용 내역</h3>\\n      </div>\\n      <ul class=\\\"divide-y divide-gray-50\\\">\\n        {{#each cardTransactions}}\\n        <li class=\\\"p-4 flex justify-between items-center\\\">\\n          <div>\\n            <p class=\\\"text-xs text-gray-400\\\">{{date}} | {{bankName}}</p>\\n            <p class=\\\"font-medium text-gray-800\\\">{{description}}</p>\\n          </div>\\n          <p class=\\\"font-bold text-red-600\\\">{{formatNumber amount}}원</p>\\n        </li>\\n        {{/each}}\\n      </ul>\\n    </div>\\n  </div>\\n</div>\\n\\n<script src=\\\"https://cdn.jsdelivr.net/npm/chart.js\\\"></script>\\n<script>\\n(function() {\\n  const ctxPie = document.getElementById('bankPieChart').getContext('2d');\\n  const ctxBar = document.getElementById('cardBarChart').getContext('2d');\\n\\n  // 파이 차트 데이터 (은행별 잔액)\\n  new Chart(ctxPie, {\\n    type: 'doughnut',\\n    data: {\\n      labels: context.charts.bankPie.labels || [],\\n      datasets: [{\\n        data: context.charts.bankPie.values || [],\\n        backgroundColor: ['#4F46E5', '#818CF8', '#A5B4FC', '#C7D2FE', '#E0E7FF'],\\n        borderWidth: 0\\n      }]\\n    },\\n    options: {\\n      responsive: true,\\n      maintainAspectRatio: false,\\n      plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } }\\n    }\\n  });\\n\\n  // 막대 그래프 데이터 (최근 3개월 월별 카드 사용액 - 샘플 데이터 기반 로직)\\n  // 실제 환경에서는 context.charts.cardMonthly 등의 데이터를 사용\\n  new Chart(ctxBar, {\\n    type: 'bar',\\n    data: {\\n      labels: ['2월', '3월', '4월'],\\n      datasets: [{\\n        label: '카드 사용액',\\n        data: [12450000, 15800000, 8900000], // 예시값: context에서 계산된 값 매핑 필요\\n        backgroundColor: '#F87171',\\n        borderRadius: 6\\n      }]\\n    },\\n    options: {\\n      responsive: true,\\n      maintainAspectRatio: false,\\n      plugins: { legend: { display: false } },\\n      scales: { y: { beginAtZero: true, grid: { display: false } }, x: { grid: { display: false } } }\\n    }\\n  });\\n})();\\n</script>\",\"customCss\":\"canvas { width: 100% !important; height: 100% !important; }\\n.rounded-2xl { border-radius: 1rem; }\\n.shadow-sm { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }\\ntable th, table td { border-bottom: 1px solid #f9fafb; }\",\"tags\":[\"'은행별 잔액 파이 차트', '은행명, 계좌번호, 잔액', '은행 거래 내역 중 최근 7일간 거래 내역', '최근 3개월 월별 카드 사용액 막대 그래프', '최근 7일간 카드 사용 내역'\"]}",
    "status": "PUBLISHED",
    "createdBy": "1",
    "createdAt": "2026-04-26T00:54:14.874Z",
    "updatedAt": "2026-04-26T11:42:46.521Z"
  },
